/**shipin.wxss**/
/* 全局样式 */
page {
  height: 100vh;
  display: flex;
  flex-direction: column;
  background-color: #ffffff;
}

.scrollarea {
  overflow-y: auto;
  width: 100%;
  max-width: 100%;
}

.container {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 30rpx 0 100rpx;
  box-sizing: border-box;
  width: 100%;
  max-width: 100%;
}

/* 标题样式 */
.title {
  font-size: 80rpx;
  font-weight: bold;
  color: #1890ff;
  margin-bottom: 30rpx;
  width: 100%;
  text-align: center;
}

/* 副标题样式 */
.subtitle {
  font-size: 28rpx;
  color: #666666;
  margin-bottom: 35rpx;
  text-align: center;
  width: 100%;
}
/* 副标题样式 */

.subtitle text {
  display: block;
  margin-bottom: 8rpx;
}

/* 二维码容器 */
.qrcode-container {
  width: 100%;
  max-width: 100%;
  padding: 0;
  box-sizing: border-box;
  display: flex;
  justify-content: center;
  margin-bottom: 30rpx;
  aspect-ratio: 37/38;
}

/* 二维码按钮 */
.qrcode-button {
  width: 100%;
  max-width: 100%;
  height: 100%;
  background-color: transparent;
  border-radius: 0;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: none;
  border: none;
  padding: 0;
  margin: 0;
  min-width: 100%;
  min-height: 100%;
}

.qrcode-button::after {
  border: none;
}

.qrcode-text {
  font-size: 32rpx;
  color: #666666;
}

/* 二维码图片 */
.qrcode-image {
  width: 100%;
  height: 100%;
  max-width: 100%;
  max-height: 100%;
  min-width: 100%;
  min-height: 100%;
  border-radius: 0;
  object-fit: cover;
}

/* 抖音账号信息 */
.douyin-account {
  width: 100%;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-top: 30rpx;
  padding: 0 15px;
  box-sizing: border-box;
}

.douyin-icon {
  width: 40rpx;
  height: 40rpx;
  margin-right: 15rpx;
  border-radius: 8rpx;
}

.account-text {
  font-size: 28rpx;
  color: #333333;
  text-align: center;
}

/* 保存图片按钮 */
.save-button {
  background-color: #1890ff;
  color: white;
  border-radius: 10rpx;
  padding: 20rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 28rpx;
  font-weight: 500;
  transition: all 0.3s ease;
  margin: 25rpx 0;
  width: 100%;
  max-width: 400rpx;
}

.save-button:hover {
  background-color: #40a9ff;
}

.save-button-text {
  font-size: 28rpx;
  font-weight: 500;
}
