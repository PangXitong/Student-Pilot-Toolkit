/* camera-watermark.wxss */

page {
  height: 100vh;
  display: flex;
  flex-direction: column;
  background-color: #ffffff;
}

.scrollarea {
  overflow-y: auto;
}

.container {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 40rpx 20rpx;
  box-sizing: border-box;
}

/* 标题 */
.title-container {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 100%;
  margin-bottom: 40rpx;
}
.title {
  font-size: 48rpx;
  font-weight: bold;
  color: #1890ff;
}

/* 拍照区域 */
.camera-area {
  width: 100%;
  display: flex;
  flex-direction: column;
  align-items: center;
  margin-bottom: 30rpx;
}
.photo-buttons {
  flex-direction: row;
  gap: 20rpx;
}

.camera-area-two {
  width: 100%;
  display: flex;
  flex-direction: row;
  gap: 20rpx;
  margin-bottom: 30rpx;
}

.camera-button-left,
.camera-button-right {
  flex: 1;
  height: 88rpx;
  background-color: #1890ff;
  color: #fff;
  border: none;
  border-radius: 14rpx;
  font-size: 30rpx;
  font-weight: 600;
  display: flex;
  align-items: center;
  justify-content: center;
  letter-spacing: 2rpx;
}
.camera-button-left:active,
.camera-button-right:active {
  background-color: #096dd9;
}
.camera-button-right {
  background-color: #52c41a;
}
.camera-button-right:active {
  background-color: #389e0d;
}
.camera-btn-orange {
  flex: 1;
  height: 88rpx;
  background-color: #faad14;
  color: #fff;
  border: none;
  border-radius: 14rpx;
  font-size: 30rpx;
  font-weight: 600;
  display: flex;
  align-items: center;
  justify-content: center;
  letter-spacing: 2rpx;
}
.camera-btn-orange:active {
  background-color: #d08700;
}
.camera-btn-green {
  flex: 1;
  height: 88rpx;
  background-color: #52c41a;
  color: #fff;
  border: none;
  border-radius: 14rpx;
  font-size: 30rpx;
  font-weight: 600;
  display: flex;
  align-items: center;
  justify-content: center;
  letter-spacing: 2rpx;
}
.camera-btn-green:active {
  background-color: #389e0d;
}

.camera-button {
  width: 100%;
  height: 88rpx;
  background-color: #1890ff;
  color: #fff;
  border: none;
  border-radius: 14rpx;
  font-size: 32rpx;
  font-weight: 600;
  display: flex;
  align-items: center;
  justify-content: center;
  letter-spacing: 4rpx;
}
.camera-button:active {
  background-color: #096dd9;
}


.camera-button-text {
  font-size: 32rpx;
  font-weight: 600;
  letter-spacing: 4rpx;
}

.photo-preview {
  width: calc(100% + 40rpx);
  flex-shrink: 0;
  margin: 24rpx -20rpx 0;
  border-radius: 14rpx;
}

/* 水印表单 */
.watermark-form {
  width: 100%;
  background-color: #f5f5f5;
  border-radius: 20rpx;
  padding: 30rpx;
  margin-bottom: 30rpx;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.1);
  box-sizing: border-box;
}

.form-title {
  display: flex;
  align-items: center;
  justify-content: space-between;
  font-size: 32rpx;
  font-weight: bold;
  color: #1890ff;
  margin-bottom: 24rpx;
}

.clear-form-btn {
  font-size: 24rpx;
  color: #666;
  padding: 0 16rpx;
  margin: 0;
  line-height: 1.8;
}

.input-row {
  display: flex;
  align-items: center;
  margin-bottom: 20rpx;
}
.input-label {
  width: 160rpx;
  font-size: 28rpx;
  color: #333;
  flex-shrink: 0;
}
.input-box {
  flex: 1;
  height: 72rpx;
  background-color: #fff;
  border: 2rpx solid #d9d9d9;
  border-radius: 10rpx;
  padding: 0 20rpx;
  font-size: 28rpx;
  color: #333;
  box-sizing: border-box;
}
.input-box:focus {
  border-color: #1890ff;
}

/* 主操作按钮 */
.action-button {
  width: 100%;
  min-height: 88rpx;
  background-color: #1890ff;
  color: #fff;
  border: none;
  border-radius: 14rpx;
  font-size: 32rpx;
  font-weight: 600;
  margin-top: 10rpx;
  letter-spacing: 4rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 0 24rpx;
  box-sizing: border-box;
}
.action-button:active {
  background-color: #096dd9;
}

/* 水印预览 */
.watermark-preview {
  width: 100%;
  margin-top: 28rpx;
  background-color: #e6f7ff;
  border-radius: 14rpx;
  padding: 24rpx;
  box-sizing: border-box;
}
.preview-label {
  font-size: 24rpx;
  color: #1890ff;
  margin-bottom: 16rpx;
  font-weight: 600;
}
.watermarked-image {
  width: 100%;
  border-radius: 10rpx;
}

/* 保存选项 */
.save-options {
  width: 100%;
  margin-top: 24rpx;
  background-color: #f5f5f5;
  border-radius: 14rpx;
  padding: 24rpx 30rpx;
}
.save-option-row {
  display: flex;
  align-items: center;
}
.save-option-text {
  font-size: 28rpx;
  color: #333;
  margin-left: 16rpx;
}

/* 操作按钮组 */
.action-buttons {
  width: 100%;
  display: flex;
  gap: 20rpx;
  margin-top: 24rpx;
}

.reset-button {
  flex: 1;
  height: 88rpx;
  background-color: #fff;
  color: #ff4d4f;
  border: 2rpx solid #ff4d4f;
  border-radius: 14rpx;
  font-size: 32rpx;
  font-weight: 600;
  display: flex;
  align-items: center;
  justify-content: center;
}
.reset-button:active {
  background-color: #fff1f0;
}

.save-button {
  flex: 2;
  height: 88rpx;
  background-color: #52c41a;
  color: #fff;
  border: none;
  border-radius: 14rpx;
  font-size: 32rpx;
  font-weight: 600;
  display: flex;
  align-items: center;
  justify-content: center;
}
.save-button:active {
  background-color: #389e0d;
}

/* 时间开关行 */
.toggle-row {
  margin-top: 16rpx;
  margin-bottom: 0;
}
.toggle-label {
  display: flex;
  align-items: center;
}
.toggle-text {
  font-size: 28rpx;
  color: #333;
  margin-left: 12rpx;
}

/* 隐藏的 canvas */
.hidden-canvas {
  position: fixed;
  top: -9999px;
  left: -9999px;
  width: 1px;
  height: 1px;
  opacity: 0;
}

/* 底部间距 */
.bottom-spacing {
  height: 50rpx;
}

.ad-wrap {
  width: calc(100% + 40rpx);
  margin: 30rpx -20rpx 20rpx;
}