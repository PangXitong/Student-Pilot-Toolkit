/* time-calculator.wxss */

/* 全局样式 */
page {
  height: 100vh;
  display: flex;
  flex-direction: column;
  background-color: #ffffff;
  font-family: 'PingFang SC', 'Helvetica Neue', Arial, sans-serif;
  color: #333;
}

.scrollarea {
  flex: 1;
  overflow-y: auto;
}

.container {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 40rpx 0;
  box-sizing: border-box;
  width: 100%;
}

/* 标题样式 */
.title-container {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 100%;
  margin-bottom: 40rpx;
}

.title {
  font-size: 90rpx;
  font-weight: bold;
  color: #1890ff;
}

/* 当前UTC时间 */
.current-utc {
  width: calc(100% - 10rpx);
  background-color: #e6f7ff;
  padding: 30rpx;
  border-radius: 20rpx;
  margin-bottom: 30rpx;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.1);
  margin-left: 5rpx;
  margin-right: 5rpx;
  box-sizing: border-box;
}

.current-utc-label {
  font-size: 28rpx;
  color: #333;
  margin-bottom: 15rpx;
  font-weight: 500;
}

.current-utc-time {
  font-size: 36rpx;
  font-weight: bold;
  color: #1890ff;
}

/* 计算器部分 */
.calculator-section {
  width: calc(100% - 10rpx);
  background-color: #f5f5f5;
  padding: 30rpx;
  border-radius: 20rpx;
  margin-bottom: 30rpx;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.1);
  margin-left: 5rpx;
  margin-right: 5rpx;
  box-sizing: border-box;
}

.section-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 25rpx;
  padding-bottom: 15rpx;
  border-bottom: 1rpx solid #e5e5e5;
  background: linear-gradient(90deg, #91c5ff 0%, #f5faff 100%);
  padding-left: 20rpx;
  border-radius: 10rpx;
  height: 50rpx;
  line-height: 50rpx;
}

/* 输入组 */
.input-group {
  margin-bottom: 25rpx;
}

.input-label {
  font-size: 28rpx;
  color: #333;
  margin-bottom: 15rpx;
  font-weight: 500;
}

.time-inputs {
  display: flex;
  gap: 15rpx;
}

.picker {
  flex: 1;
  padding: 20rpx;
  background-color: #ffffff;
  border: 1rpx solid #e5e5e5;
  border-radius: 10rpx;
  font-size: 28rpx;
  color: #333;
  text-align: center;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.05);
}

.input-field {
  padding: 20rpx;
  background-color: #ffffff;
  border: 1rpx solid #e5e5e5;
  border-radius: 10rpx;
  font-size: 28rpx;
  color: #333;
  width: 100%;
  box-sizing: border-box;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.05);
}

.longitude-input {
  height: 100rpx;
}

/* 计算按钮 */
.calculate-button {
  background-color: #1890ff;
  color: #fff;
  border: none;
  border-radius: 10rpx;
  padding: 20rpx;
  font-size: 28rpx;
  font-weight: bold;
  margin: 25rpx 0;
  width: 100%;
  box-shadow: 0 4rpx 12rpx rgba(24, 144, 255, 0.3);
  transition: all 0.3s ease;
}

.calculate-button:hover {
  background-color: #40a9ff;
  transform: translateY(-2rpx);
  box-shadow: 0 6rpx 16rpx rgba(24, 144, 255, 0.4);
}

/* 结果部分 */
.result-section {
  margin-top: 25rpx;
  padding-top: 25rpx;
  border-top: 1rpx solid #e5e5e5;
}

.result-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 15rpx;
  padding: 15rpx;
  background-color: #ffffff;
  border-radius: 10rpx;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.05);
}

.result-label {
  font-size: 28rpx;
  color: #333;
  font-weight: 500;
}

.result-value {
  font-size: 32rpx;
  font-weight: bold;
  color: #1890ff;
}

/* 底部间距 */
.bottom-spacing {
  height: 50rpx;
}