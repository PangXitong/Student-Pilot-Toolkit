/**share.wxss**/
page {
  background-color: #ffffff;
}

.container {
  display: flex;
  flex-direction: column;
  min-height: 100vh;
  padding: 40rpx 20rpx;
  box-sizing: border-box;
}

.header {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  margin-bottom: 60rpx;
}

.title {
  font-size: 80rpx;
  font-weight: bold;
  color: #1890ff;
  text-align: center;
  margin-bottom: 10rpx;
}

.subtitle {
  font-size: 24rpx;
  color: #666;
  text-align: center;
  line-height: 1.4;
  padding: 0 20rpx;
}

.content {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: flex-start;
  width: 100%;
}

/* 图片容器 */
.image-container {
  display: flex;
  justify-content: space-between;
  width: 100%;
  max-width: 600rpx;
  margin-bottom: 60rpx;
}

/* 图片项 */
.image-item {
  width: 48%;
  display: flex;
  flex-direction: column;
  align-items: center;
  min-height: 400rpx;
  justify-content: space-between;
}

/* 图片包装器 */
.image-wrapper {
  width: 100%;
  aspect-ratio: 1;
  background-color: #f5f5f5;
  border-radius: 20rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  overflow: hidden;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.1);
  margin-bottom: 20rpx;
}

.image-wrapper-43-49 {
  aspect-ratio: 43/49;
}

/* 分享图片 */
.share-image {
  width: 100%;
  height: 100%;
  object-fit: cover;
}

/* 图片操作 */
.image-actions {
  width: 100%;
  display: flex;
  justify-content: center;
}

/* 下载按钮 */
.download-button {
  width: 100%;
  height: 60rpx;
  background-color: #1890ff;
  color: white;
  font-size: 28rpx;
  border-radius: 30rpx;
  margin: 0;
  display: flex;
  align-items: center;
  justify-content: center;
}

/* 链接部分 */
.link-section {
  width: 100%;
  max-width: 600rpx;
  margin-bottom: 60rpx;
}

/* 链接标签 */
.link-label {
  display: block;
  font-size: 28rpx;
  color: #666;
  margin-bottom: 10rpx;
}

/* 链接容器 */
.link-container {
  display: flex;
  align-items: center;
  background-color: #f5f5f5;
  border-radius: 10rpx;
  padding: 0 20rpx;
  height: 80rpx;
  box-sizing: border-box;
}

/* 链接文本 */
.link-text {
  flex: 1;
  font-size: 24rpx;
  color: #333;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

/* 复制按钮 */
.copy-button {
  width: 100rpx;
  height: 50rpx;
  background-color: #1890ff;
  color: white;
  font-size: 28rpx;
  border-radius: 25rpx;
  margin: 0 0 0 10rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

/* 返回按钮 */
.back-button {
  width: 100%;
  max-width: 600rpx;
  height: 80rpx;
  background-color: #f5f5f5;
  color: #333;
  font-size: 28rpx;
  border-radius: 40rpx;
  margin-top: 20rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

/* 底部间距 */
.bottom-spacing {
  height: 50rpx;
}