page {
  background-color: #ffffff;
}

.container {
  display: flex;
  flex-direction: column;
  min-height: 100vh;
  padding: 40rpx 20rpx;
  box-sizing: border-box;
}

.header {
  display: flex;
  justify-content: center;
  margin-bottom: 60rpx;
}

.title {
  font-size: 40rpx;
  font-weight: bold;
  color: #ff6b6b;
  text-align: center;
}

.content {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: flex-start;
  width: 100%;
}

.input-section {
  width: 100%;
  max-width: 600rpx;
  margin-bottom: 60rpx;
}

.input-item {
  margin-bottom: 30rpx;
}

.label {
  display: block;
  font-size: 28rpx;
  color: #666;
  margin-bottom: 10rpx;
}

.input {
  width: 100%;
  height: 80rpx;
  border: 2rpx solid #ff6b6b;
  border-radius: 10rpx;
  padding: 0 20rpx;
  font-size: 28rpx;
  box-sizing: border-box;
}

.calculate-button {
  width: 100%;
  max-width: 600rpx;
  height: 80rpx;
  background-color: #ff6b6b;
  color: white;
  font-size: 28rpx;
  border-radius: 40rpx;
  margin-bottom: 60rpx;
}

.result-section {
  width: 100%;
  max-width: 600rpx;
  background-color: #fff5f5;
  border-radius: 20rpx;
  padding: 40rpx;
  margin-bottom: 60rpx;
  text-align: center;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.1);
}

.result-label {
  display: block;
  font-size: 36rpx;
  color: #666;
  margin-bottom: 30rpx;
}

.important-tip {
  display: flex;
  flex-direction: column;
  align-items: flex-start;
  background-color: #fff7e6;
  border: 1rpx solid #ffd591;
  border-radius: 12rpx;
  padding: 24rpx;
  margin-bottom: 30rpx;
  text-align: left;
  line-height: 1.6;
}

.important-warning {
  color: #ff4d4f;
  font-weight: 700;
  font-size: 28rpx;
  margin-bottom: 8rpx;
}

.important-tip text:nth-child(2) {
  font-size: 26rpx;
  color: #666;
}

.basic-rates {
  display: flex;
  justify-content: center;
  margin-bottom: 40rpx;
}

.rate-item {
  display: flex;
  flex-direction: column;
  align-items: center;
}

.rate-label {
  font-size: 32rpx;
  color: #666;
  margin-bottom: 10rpx;
}

.rate-value {
  font-size: 72rpx;
  font-weight: bold;
  color: #ff6b6b;
}

.rate-unit {
  font-size: 28rpx;
  color: #999;
  margin-top: 5rpx;
}

.zones-section {
  width: 100%;
}

.zones-title {
  display: block;
  font-size: 28rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 20rpx;
  text-align: left;
}

.zone-item {
  background-color: #ffffff;
  border-radius: 12rpx;
  padding: 20rpx;
  margin-bottom: 16rpx;
  text-align: left;
  border-left: 4rpx solid #ff6b6b;
}

.zone-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 10rpx;
}

.zone-name {
  font-size: 26rpx;
  font-weight: bold;
}

.zone-range {
  font-size: 24rpx;
  color: #666;
}

.zone-description {
  font-size: 22rpx;
  color: #888;
  line-height: 1.5;
}

.history-section {
  width: 100%;
  max-width: 700rpx;
  margin-bottom: 40rpx;
  background-color: #ffffff;
  border-radius: 16rpx;
  border: 2rpx solid #e8e8e8;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.06);
}

.history-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 24rpx 30rpx;
  border-bottom: 2rpx solid #e8e8e8;
}

.history-title {
  flex: 1;
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
}

.clear-all-button {
  min-width: 0 !important;
  width: 200rpx!important;
  height: 48rpx;
  background-color: #ff6265;
  color: white;
  font-size: 22rpx;
  padding: 0 12rpx;
  border-radius: 10rpx;
  border: none;
  line-height: 48rpx;
  margin-left: 16rpx;
  flex-shrink: 0;
  box-sizing: border-box;
}

.clear-all-button::after {
  border: none;
}

.history-list {
  max-height: 600rpx;
  padding: 10rpx 0;
}

.history-item {
  display: flex;
  align-items: center;
  padding: 20rpx 24rpx;
  border-bottom: 1rpx solid #f0f0f0;
  background-color: #ffffff;
  transition: background-color 0.2s ease;
  overflow: hidden;
}

.history-item:last-child {
  border-bottom: none;
}

.history-item:active {
  background-color: #f5f5f5;
}

.history-info {
  flex: 1;
  min-width: 150px;
  display: flex;
  flex-direction: column;
  gap: 6rpx;
  overflow: hidden;
}

.history-time {
  font-size: 22rpx;
  color: #999;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.history-data {
  font-size: 24rpx;
  color: #666;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.history-rate {
  display: flex;
  flex-direction: column;
  align-items: flex-start;
  gap: 6rpx;
  flex-shrink: 0;
  margin-left: 12rpx;
}

.rate-value-history {
  font-size: 32rpx;
  font-weight: bold;
  color: #ff6b6b;
}

.rate-unit-history {
  font-size: 20rpx;
  color: #999;
}

.delete-button {
  min-width: 0 !important;
  width: 100rpx!important;
  height: 48rpx;
  background-color: #ff6265;
  color: white;
  font-size: 22rpx;
  padding: 0 12rpx;
  border-radius: 10rpx;
  border: none;
  line-height: 48rpx;
  margin-left: 16rpx;
  flex-shrink: 0;
  box-sizing: border-box;
}

.delete-button::after {
  border: none;
}

.delete-button:active {
  background-color: #d9363e;
}

.history-empty {
  padding: 80rpx 40rpx;
  text-align: center;
}

.empty-text {
  font-size: 26rpx;
  color: #999;
}

.back-button {
  width: 100%;
  max-width: 600rpx;
  height: 80rpx;
  background-color: #f5f5f5;
  color: #333;
  font-size: 28rpx;
  border-radius: 40rpx;
  margin-top: 20rpx;
}

.formula-section {
  width: 100%;
  max-width: 600rpx;
  background-color: #f9f9f9;
  border-radius: 15rpx;
  padding: 20rpx;
  margin-top: 30rpx;
  border-left: 4rpx solid #ff6b6b;
}

.formula-title {
  display: block;
  font-size: 24rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 10rpx;
}

.formula-content {
  display: block;
  font-size: 22rpx;
  color: #666;
  margin-bottom: 5rpx;
  font-family: 'Courier New', monospace;
}

.formula-note {
  display: block;
  font-size: 20rpx;
  color: #999;
  margin-top: 10rpx;
}

.important-warning {
  color: #ff4d4f;
  font-weight: 700;
}