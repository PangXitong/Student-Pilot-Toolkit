page {
  background-color: #ffffff;
  height: 100vh;
}

.page-container {
  display: flex;
  flex-direction: column;
  height: 100vh;
}

.content-area {
  flex: 1;
  overflow-y: auto;
  padding-bottom: 160rpx;
}

.tab-content {
  display: none;
}

.tab-content.active {
  display: block;
}

.content-inner {
  padding: 32rpx 0 0;
  width: 100%;
  box-sizing: border-box;
}

.page-title {
  font-size: 56rpx;
  font-weight: 700;
  color: #000000;
  line-height: 1.2;
  margin-bottom: 32rpx;
  text-align: left;
  margin-left: 40rpx;
}

.search-box {
  background: #e9e9eb;
  border-radius: 20rpx;
  padding: 24rpx 20rpx;
  margin-bottom: 40rpx;
  margin-left: 20rpx;
  margin-right: 20rpx;
}

.search-input {
  font-size: 32rpx;
  color: #000000;
}

.section-title-small {
  font-size: 28rpx;
  font-weight: 600;
  color: #6e6e73;
  margin-bottom: 16rpx;
  text-align: left;
  margin-left: 40rpx;
}

.section-title {
  font-size: 36rpx;
  font-weight: 700;
  color: #1d1d1f;
  margin-bottom: 24rpx;
  text-align: left;
  margin-left: 40rpx;
}

.featured-section {
  margin-bottom: 56rpx;
}

.featured-scroll {
  white-space: nowrap;
  box-sizing: border-box;
}

.featured-card {
  display: inline-flex;
  flex-direction: column;
  width: 600rpx;
  margin-right: 24rpx;
  flex-shrink: 0;
}

.featured-card:first-child {
  margin-left: 32rpx;
}

.featured-card:last-child {
  margin-right: 0;
}

.featured-image {
  width: 600rpx;
  height: 400rpx;
  border-radius: 24rpx;
  margin-bottom: 16rpx;
  background-color: #e3f2fd;
}

.featured-text {
  font-size: 28rpx;
  font-weight: 500;
  color: #1d1d1f;
  text-align: center;
  line-height: 1.4;
}

.tools-section {
  margin-bottom: 56rpx;
}

.tools-scroll {
  white-space: nowrap;
  box-sizing: border-box;
}

.tool-item {
  display: inline-flex;
  flex-direction: column;
  width: 380rpx;
  margin-right: 24rpx;
  flex-shrink: 0;
}

.tool-item:first-child {
  margin-left: 32rpx;
}

.tool-item:last-child {
  margin-right: 0;
}

.tool-image {
  width: 380rpx;
  height: 254rpx;
  border-radius: 24rpx;
  margin-bottom: 16rpx;
  background-color: #e3f2fd;
}

.tool-text {
  font-size: 28rpx;
  font-weight: 500;
  color: #1d1d1f;
  text-align: center;
  line-height: 1.4;
}

.search-results {
  display: flex;
  flex-wrap: wrap;
  justify-content: space-between;
  margin: 0 32rpx 40rpx;
}

.search-tool-item {
  width: 48%;
  display: flex;
  flex-direction: column;
  margin-bottom: 40rpx;
}

.search-tool-image {
  width: 100%;
  height: 254rpx;
  border-radius: 24rpx;
  margin-bottom: 16rpx;
  background-color: #e3f2fd;
}

.search-tool-text {
  font-size: 28rpx;
  color: #1d1d1f;
  text-align: center;
  line-height: 1.4;
}

.no-results {
  padding: 80rpx 0;
  text-align: center;
}

.no-results-text {
  font-size: 28rpx;
  color: #86868b;
}

.beian-area {
  padding: 40rpx 0 100rpx;
  text-align: center;
}

.beian-text {
  font-size: 24rpx;
  color: #86868b;
}

.tab2-ad-wrapper {
  padding: 0 40rpx 200rpx;
  box-sizing: border-box;
}



.links-grid {
  display: flex;
  flex-wrap: wrap;
  justify-content: space-between;
  box-sizing: border-box;
  margin-left: 40rpx;
  margin-right: 40rpx;
}

.link-item {
  width: 48%;
  display: flex;
  flex-direction: column;
  margin-bottom: 40rpx;
}

.link-image {
  width: 100%;
  height: 280rpx;
  border-radius: 24rpx;
  margin-bottom: 16rpx;
  background-color: #e3f2fd;
  border: 2rpx solid #d9d9d9;
}

.link-text {
  font-size: 28rpx;
  font-weight: 500;
  color: #1d1d1f;
  text-align: center;
  line-height: 1.4;
}

.author-title {
  font-size: 70rpx;
  font-weight: 700;
  color: #000000;
  line-height: 1.2;
  margin-bottom: 24rpx;
  text-align: center;
}

.author-info {
  display: flex;
  flex-direction: row;
  align-items: center;
  justify-content: center;
  margin-bottom: 80rpx;
  gap: 32rpx;
}

.author-avatar {
  width: 200rpx;
  height: 200rpx;
  border-radius: 100rpx;
  margin-bottom: 0;
  background-color: #e9e9eb;
  flex-shrink: 0;
}

.author-details {
  display: flex;
  flex-direction: column;
  align-items: flex-start;
  gap: 8rpx;
}

.author-name {
  font-size: 36rpx;
  font-weight: 600;
  color: #1d1d1f;
}

.author-title-tag {
  font-size: 32rpx;
  color: #666;
}

.author-subtitle {
  font-size: 28rpx;
  color: #666;
  text-align: center;
  line-height: 1.6;
  margin-bottom: 40rpx;
  padding: 0 40rpx;
}

.author-grid {
  display: flex;
  flex-wrap: wrap;
  justify-content: center;
  box-sizing: border-box;
  gap: 16rpx !important;
  padding: 0 40rpx;
}

.grid-item {
  width: 40%;
  display: flex;
  flex-direction: column;
  margin-bottom: 16rpx !important;
}

.grid-image {
  width: 180rpx;
  height: 180rpx;
  border-radius: 36rpx;
  margin-bottom: 12rpx;
  margin-left: auto;
  margin-right: auto;
  background-color: #ffffff;
  box-shadow: 0 12rpx 32rpx rgba(0, 0, 0, 0.18), 0 4rpx 12rpx rgba(0, 0, 0, 0.08);
  overflow: hidden;
}

.grid-text {
  font-size: 24rpx;
  font-weight: 500;
  color: #1d1d1f;
  text-align: center;
  line-height: 1.4;
}

.tab-bar {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  height: 140rpx;
  background: #ffffff;
  border-top: 1rpx solid #d2d2d7;
  display: flex;
  padding-bottom: env(safe-area-inset-bottom);
  z-index: 100;
}

.tab-item {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: 8rpx;
}

.tab-icon {
  font-size: 56rpx;
  line-height: 1;
}

.tab-label {
  font-size: 28rpx;
  font-weight: 500;
  color: #86868b;
}

.tab-item.active .tab-label {
  color: #007aff;
}
