/* speed-calculator.wxss */

page {
  height: 100vh;
  display: flex;
  flex-direction: column;
  background-color: #ffffff;
}

.scrollarea {
  flex: 1;
  overflow-y: auto;
}

.container {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 40rpx 20rpx;
  box-sizing: border-box;
}

/* 标题 */
.title-container {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 100%;
  margin-bottom: 40rpx;
}
.title {
  font-size: 90rpx;
  font-weight: bold;
  color: #1890ff;
}

/* 卡片 */
.module-card {
  width: 100%;
  background-color: #f5f5f5;
  border-radius: 20rpx;
  padding: 30rpx;
  margin-bottom: 30rpx;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.1);
  box-sizing: border-box;
}

.module-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #1890ff;
  margin-bottom: 24rpx;
}

.module-subtitle {
  font-size: 24rpx;
  color: #888;
  margin-bottom: 20rpx;
}

/* 输入行 */
.input-row {
  display: flex;
  align-items: center;
  margin-bottom: 20rpx;
}
.input-label {
  width: 160rpx;
  font-size: 28rpx;
  color: #333;
  flex-shrink: 0;
}
.input-box {
  flex: 1;
  height: 72rpx;
  background-color: #fff;
  border: 2rpx solid #d9d9d9;
  border-radius: 10rpx;
  padding: 0 20rpx;
  font-size: 28rpx;
  color: #333;
  box-sizing: border-box;
}
.input-box:focus {
  border-color: #1890ff;
}

/* 开关行 */
.toggle-row {
  display: flex;
  align-items: center;
  margin-bottom: 20rpx;
}

/* 主操作按钮 */
.action-button {
  width: 100%;
  height: 88rpx;
  background-color: #1890ff;
  color: #fff;
  border: none;
  border-radius: 14rpx;
  font-size: 32rpx;
  font-weight: 600;
  margin-top: 10rpx;
  letter-spacing: 4rpx;
}
.action-button:active {
  background-color: #096dd9;
}

/* ① 随机数结果 */
.result-box {
  margin-top: 28rpx;
  background-color: #e6f7ff;
  border-radius: 14rpx;
  padding: 24rpx;
}
.result-label {
  font-size: 24rpx;
  color: #1890ff;
  margin-bottom: 16rpx;
  font-weight: 600;
}
.result-numbers {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
}
.result-number {
  background-color: #1890ff;
  color: #fff;
  border-radius: 10rpx;
  padding: 10rpx 22rpx;
  font-size: 30rpx;
  font-weight: bold;
}

/* ② 是/否结果 */
.yesno-result {
  margin-top: 28rpx;
  text-align: center;
  font-size: 100rpx;
  font-weight: bold;
  border-radius: 20rpx;
  padding: 30rpx 0;
  letter-spacing: 8rpx;
}
.yesno-result.yes {
  background-color: #f6ffed;
  color: #52c41a;
}
.yesno-result.no {
  background-color: #fff1f0;
  color: #ff4d4f;
}

/* ③ 排列组合结果 */
.pnc-result-area {
  margin-top: 28rpx;
  background-color: #e6f7ff;
  border-radius: 14rpx;
  padding: 24rpx;
}
.pnc-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 8rpx;
}
.pnc-label {
  font-size: 28rpx;
  color: #555;
}
.pnc-value {
  font-size: 36rpx;
  font-weight: bold;
  color: #1890ff;
}
.pnc-formula {
  font-size: 22rpx;
  color: #888;
  margin-bottom: 16rpx;
}
.pnc-divider {
  height: 2rpx;
  background-color: #bae7ff;
  margin: 16rpx 0;
}

/* 底部间距 */
.bottom-spacing {
  height: 50rpx;
}

/* 历史记录 */
.history-section {
  margin-top: 28rpx;
  background-color: #fff;
  border-radius: 14rpx;
  padding: 24rpx;
  border: 2rpx solid #e6f7ff;
}
.history-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 16rpx;
}
.history-title {
  font-size: 28rpx;
  font-weight: bold;
  color: #333;
}
.history-stats {
  font-size: 24rpx;
  color: #1890ff;
}
.delete-old-btn {
  flex-shrink: 0;
  height: 64rpx;
  padding: 0 20rpx;
  background-color: #fff1f0;
  color: #ff4d4f;
  font-size: 26rpx;
  border-radius: 10rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  white-space: nowrap;
}
.history-list {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
  max-height: 360rpx;
  overflow-y: auto;
}
.history-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 16rpx;
  background-color: #fafafa;
  border-radius: 10rpx;
}
.history-info {
  flex: 1;
}
.history-date {
  font-size: 22rpx;
  color: #999;
  margin-bottom: 6rpx;
}
.history-detail {
  font-size: 24rpx;
  color: #333;
}
.history-results {
  font-size: 24rpx;
  color: #666;
  margin-top: 6rpx;
}
.history-actions {
  display: flex;
  align-items: center;
  margin-left: 16rpx;
}
.delete-btn {
  color: #ff4d4f;
  font-size: 26rpx;
  padding: 8rpx 16rpx;
}
.today-tag {
  color: #52c41a;
  font-size: 24rpx;
  padding: 8rpx 16rpx;
}
.history-empty {
  display: flex;
  justify-content: center;
  align-items: center;
  padding: 40rpx 0;
}
.history-empty-text {
  font-size: 26rpx;
  color: #999;
}
