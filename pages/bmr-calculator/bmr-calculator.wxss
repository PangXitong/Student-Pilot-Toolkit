/**bmr-calculator.wxss**/
page {
  background-color: #ffffff;
}

.container {
  display: flex;
  flex-direction: column;
  min-height: 100vh;
  padding: 40rpx 20rpx;
  box-sizing: border-box;
}

.header {
  display: flex;
  justify-content: center;
  margin-bottom: 60rpx;
}

.title {
  font-size: 40rpx;
  font-weight: bold;
  color: #1890ff;
  text-align: center;
}

.content {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: flex-start;
  width: 100%;
}

.input-section {
  width: 100%;
  max-width: 600rpx;
  margin-bottom: 60rpx;
}

.input-item {
  margin-bottom: 30rpx;
}

.label {
  display: block;
  font-size: 28rpx;
  color: #666;
  margin-bottom: 10rpx;
}

.input {
  width: 100%;
  height: 80rpx;
  border: 2rpx solid #1890ff;
  border-radius: 10rpx;
  padding: 0 20rpx;
  font-size: 28rpx;
  box-sizing: border-box;
}

.gender-selector {
  display: flex;
  gap: 20rpx;
}

.gender-option {
  flex: 1;
  height: 80rpx;
  border: 2rpx solid #1890ff;
  border-radius: 10rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 28rpx;
  color: #1890ff;
  box-sizing: border-box;
  transition: all 0.3s ease;
}

.gender-option.selected {
  background-color: #1890ff;
  color: white;
}

.gender-text {
  font-size: 28rpx;
}

.calculate-button {
  width: 100%;
  max-width: 600rpx;
  height: 80rpx;
  background-color: #1890ff;
  color: white;
  font-size: 28rpx;
  border-radius: 40rpx;
  margin-bottom: 60rpx;
}

.result-section {
  width: 100%;
  max-width: 600rpx;
  background-color: #f5f5f5;
  border-radius: 20rpx;
  padding: 40rpx;
  margin-bottom: 60rpx;
  text-align: center;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.1);
}

.result-label {
  display: block;
  font-size: 28rpx;
  color: #666;
  margin-bottom: 20rpx;
}

.result-value {
  display: block;
  font-size: 60rpx;
  font-weight: bold;
  color: #1890ff;
  margin-bottom: 20rpx;
}

.result-description {
  display: block;
  font-size: 24rpx;
  color: #666;
  line-height: 1.5;
}

.back-button {
  width: 100%;
  max-width: 600rpx;
  height: 80rpx;
  background-color: #f5f5f5;
  color: #333;
  font-size: 28rpx;
  border-radius: 40rpx;
  margin-top: 20rpx;
}

.formula-section {
  width: 100%;
  max-width: 600rpx;
  background-color: #f9f9f9;
  border-radius: 15rpx;
  padding: 20rpx;
  margin-top: 30rpx;
  border-left: 4rpx solid #1890ff;
}

.formula-title {
  display: block;
  font-size: 24rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 10rpx;
}

.formula-content {
  display: block;
  font-size: 22rpx;
  color: #666;
  margin-bottom: 5rpx;
  font-family: 'Courier New', monospace;
}

.formula-note {
  display: block;
  font-size: 20rpx;
  color: #999;
  margin-top: 10rpx;
}