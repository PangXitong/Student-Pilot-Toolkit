/** e6b-flight-computer.wxss **/
/* 全局样式 */
page {
  height: 100vh;
  display: flex;
  flex-direction: column;
  background-color: #ffffff;
}

.scrollarea {
  overflow-y: auto;
}

.container {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 40rpx 20rpx;
  box-sizing: border-box;
}

/* 标题容器 */
.title-container {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 100%;
  margin-bottom: 20rpx;
}

/* 标题样式 */
.title {
  font-size: 60rpx;
  font-weight: bold;
  color: #1890ff;
  text-align: center;
}

/* 副标题样式 */
.subtitle {
  font-weight: 900;
  font-size: 24rpx;
  color: #333333;
  text-align: center;
  margin-bottom: 40rpx;
  line-height: 1.5;
}

.subtitle text {
  display: block;
  margin-bottom: 8rpx;
}

.subtitle text:last-child {
  margin-bottom: 0;
}

/* 计算类型选择 */
.calculator-type {
  width: 100%;
  margin-bottom: 40rpx;
}

.type-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #333333;
  margin-bottom: 20rpx;
  text-align: center;
}

.type-buttons {
  display: flex;
  justify-content: space-between;
  gap: 20rpx;
}

.type-button {
  flex: 1;
  background-color: #f5f5f5;
  color: #333333;
  border: 1rpx solid #d9d9d9;
  border-radius: 10rpx;
  padding: 20rpx;
  font-size: 28rpx;
  font-weight: bold;
}

.type-button:active {
  background-color: #e6f7ff;
  color: #1890ff;
}

/* 计算器部分 */
.calculator-section {
  width: 100%;
  background-color: #f5f5f5;
  border-radius: 20rpx;
  padding: 30rpx;
  box-sizing: border-box;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.1);
  margin-bottom: 30rpx;
}

.section-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #333333;
  margin-bottom: 20rpx;
  text-align: center;
}

/* 输入组 */
.input-group {
  display: flex;
  align-items: center;
  margin-bottom: 20rpx;
}

.input-label {
  width: 180rpx;
  font-size: 28rpx;
  color: #333333;
}

.input-field {
  flex: 1;
  height: 80rpx;
  border: 1rpx solid #d9d9d9;
  border-radius: 10rpx;
  padding: 0 20rpx;
  font-size: 28rpx;
  background-color: #ffffff;
}

/* 计算按钮 */
.calculate-button {
  width: 100%;
  height: 80rpx;
  background-color: #1890ff;
  color: white;
  border: none;
  border-radius: 10rpx;
  font-size: 32rpx;
  font-weight: bold;
  margin-bottom: 30rpx;
}

/* 结果部分 */
.result-section {
  background-color: #ffffff;
  border-radius: 10rpx;
  padding: 20rpx;
  box-sizing: border-box;
}

.result-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 15rpx;
}

.result-item:last-child {
  margin-bottom: 0;
}

.result-label {
  font-size: 28rpx;
  color: #333333;
}

.result-value {
  font-size: 28rpx;
  color: #1890ff;
  font-weight: bold;
}

/* 输入区域 */
.input-section {
  background-color: #f5f5f5;
  border-radius: 10rpx;
  padding: 20rpx;
  box-sizing: border-box;
  margin-bottom: 20rpx;
}

/* 副标题 */
.section-subtitle {
  font-size: 26rpx;
  font-weight: bold;
  color: #333333;
  margin-bottom: 15rpx;
}

/* 算法说明部分 */
.algorithm-section {
  background-color: #ffffff;
  border-radius: 10rpx;
  padding: 20rpx;
  box-sizing: border-box;
  margin-top: 20rpx;
}

.algorithm-title {
  font-size: 28rpx;
  font-weight: bold;
  color: #333333;
  margin-bottom: 15rpx;
}

.algorithm-content {
  font-size: 24rpx;
  color: #666666;
}

.algorithm-step {
  margin-bottom: 10rpx;
  line-height: 1.4;
}

.algorithm-step:last-child {
  margin-bottom: 0;
}

/* 底部间距 */
.bottom-spacing {
  height: 50rpx;
}
